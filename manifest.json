{
  "manifest_version": 3,
  "name": "Typika",
  "version": "1.0.1",
  "description": "Hover to inspect fonts. Click to copy name and search.",
  "author": "uxwisp",
  "homepage_url": "https://github.com/uxwisp/Typika",
  "permissions": [
    "activeTab",
    "scripting",
    "search",
    "contextMenus"
  ],
  "host_permissions": [
    "https://plausible.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Typika \u2014 click to activate",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}